{
  "name": "food-delivery-mern",
  "version": "1.0.0",
  "description": "Food Delivery Web Application — MERN Stack",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "npm run build --workspace=client",
    "lint": "npm run lint --workspace=server && npm run lint --workspace=client"
  },
  "keywords": [
    "food-delivery",
    "mern",
    "react",
    "express",
    "mongodb"
  ],
  "author": "AhmedLaiq34",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
